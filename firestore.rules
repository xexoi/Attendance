rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'director' || 
         (request.auth.token.email == 'nahommamo888@gmail.com' && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }

    function isRep() {
      return isAuthenticated() && getUserData().role == 'rep';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow create: if isAuthenticated() && (isAdmin() || (isOwner(uid) && request.auth.token.email == 'nahommamo888@gmail.com'));
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && isAdmin();
    }

    match /sections/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /subjects/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /schedules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        isAdmin() || 
        isTeacher() || 
        isRep()
      );
      // Note: More granular checks for teacher/rep could be added here to ensure they only mark their own classes
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
